{
  "name": "rancher-mcp",
  "version": "0.1.1-beta.0",
  "description": "Rancher-only MCP server with pass-through authorization.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "rancher-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/*.md",
    "docs/logo.svg",
    "docs/.vitepress/config.ts",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "mcp",
    "rancher",
    "fleet",
    "claude",
    "copilot",
    "codex"
  ],
  "author": "Jasonrve"
}
